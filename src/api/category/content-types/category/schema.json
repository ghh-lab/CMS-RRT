{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Categorie"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "sortOrder": {
      "type": "integer",
      "default": 0
    },
    "spectacles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::spectacle.spectacle",
      "mappedBy": "category"
    }
  }
}
