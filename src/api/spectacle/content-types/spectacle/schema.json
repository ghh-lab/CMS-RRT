    },
    "description": {
      "type": "text"
    },
    "salle": {
      "type": "enumeration",
      "enum": [
        "Grand théâtre de la Maison de la Culture (Papeete)",
        "Petit théâtre de la Maison de la Culture (Papeete)",
        "Hotel Le TAHITI",
        "Place To'ata (Papeete)"
      ]
    },
    "thumbnail": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "heroBanner": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "videoPreviewUrl": {
      "type": "string"
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::category.category",
      "inversedBy": "spectacles"
    },
    "priceXPF": {
      "type": "decimal"
    },
